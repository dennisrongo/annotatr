# Annotatr release credentials.
#
# Copy this file to .env.release (which is gitignored) and fill in your values.
# scripts/release-mac.sh and scripts/release-win.ps1 source .env.release automatically.
#
# The APPLE_* vars below are macOS-only (code signing + notarization). On a
# WINDOWS machine you only need TAURI_SIGNING_PRIVATE_KEY (the SAME updater key
# as macOS — copy ~/.tauri/annotatr-updater.key over). Windows installers are not
# Authenticode-signed in this setup, so SmartScreen warns on first install.
#
# DO NOT commit .env.release — it contains your notarization secret.

# --- Code signing -----------------------------------------------------------
# Your "Developer ID Application" identity, exactly as shown by:
#   security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY="Developer ID Application: Lean Code Automation LLC (PMNAQBZ3KN)"

# --- Notarization (Apple ID + app-specific password) ------------------------
# The Apple account email tied to your Developer Program membership.
APPLE_ID="you@example.com"

# An APP-SPECIFIC password (NOT your Apple ID login password). Create one at:
#   https://appleid.apple.com  ->  Sign-In and Security  ->  App-Specific Passwords
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Your 10-character Apple Developer Team ID.
APPLE_TEAM_ID="PMNAQBZ3KN"

# Updater payload signing key (separate from the Apple Developer cert).
# Generate once:  npx tauri signer generate -w ~/.tauri/annotatr-updater.key -p "" --ci
# Tauri reads TAURI_SIGNING_PRIVATE_KEY (a path OR the key contents) — NOT _PATH.
# Back up this key file: losing it means existing installs can never auto-update.
TAURI_SIGNING_PRIVATE_KEY="/Users/you/.tauri/annotatr-updater.key"
# Must equal the key's password. Use "" ONLY if the key has no password (as with
# the `-p ""` generate command above). On Windows the release script signs via
# `tauri signer sign -p <this>`, so an empty value here is fine — but it MUST
# match, or signing fails / the build prompts.
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""
