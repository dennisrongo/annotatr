{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Annotatr",
  "version": "0.2.1",
  "identifier": "com.annotatr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:35421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Annotatr Settings",
        "width": 660,
        "height": 520,
        "minWidth": 580,
        "minHeight": 440,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "visible": false
      },
      {
        "label": "mini-panel",
        "title": "Annotatr",
        "url": "mini-panel.html",
        "width": 462,
        "height": 56,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "acceptFirstMouse": true,
        "visibleOnAllWorkspaces": true,
        "closable": false,
        "minimizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Annotatr",
    "copyright": "Copyright © 2025 Annotatr",
    "category": "Graphics and Design",
    "shortDescription": "Screen annotation tool for recordings",
    "longDescription": "A cross-platform screen annotation overlay tool that lets users draw arrows, circles, boxes, freehand drawings, highlights, and text on their screen in real-time while recording with any screen capture software.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxMzEzMzdBNUM2NDI1QUQKUldTdEpXUmNlak14TVdUS05sZkIrbkdpQ1JaV01Cbzl6dC90bzhWcG1xR0FQc3JtV0xCWmxFUjAK",
      "endpoints": [
        "https://github.com/dennisrongo/annotatr/releases/latest/download/latest.json"
      ]
    }
  }
}
